# ==========================================
# MangaBook V2 - Git ignored files
# ==========================================

# =========================
# Python
# =========================
__pycache__/
*.py[cod]
*$py.class
*.so

# =========================
# Packaging / build
# =========================
build/
dist/
.eggs/
*.egg-info/
*.egg
pip-wheel-metadata/

# =========================
# Virtual environments
# =========================
.venv/
venv/
env/
ENV/

# =========================
# Flask / database
# =========================
instance/
!instance/.gitkeep

*.db
*.sqlite
*.sqlite3
*.db-journal
*.sqlite-journal

# =========================
# Environment variables / secrets
# =========================
.env
.env.*
!.env.example

# =========================
# Flask runtime
# =========================
.webassets-cache/

# =========================
# Tests / coverage / caches
# =========================
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/
.hypothesis/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
coverage.xml
.cache/

# =========================
# Static uploads generated at runtime
# =========================
app/static/uploads/*
!app/static/uploads/.gitkeep

# =========================
# Front-end / Node tooling
# =========================
node_modules/
.vite/
.parcel-cache/
coverage/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# Editors / OS
# =========================
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo

# =========================
# Logs / temporary files
# =========================
*.log
logs/
tmp/
temp/

# =========================
# Certificates / keys
# =========================
*.pem
*.key
*.crt